# Copy to .env and fill in. Never commit .env.

# Tradier sandbox token: sign up at https://documentation.tradier.com/ (free, no brokerage account needed)
TRADIER_TOKEN=your-sandbox-token-here

# sandbox (15-min delayed data, free) or production (requires funded brokerage account)
TRADIER_ENV=sandbox

# Neon connection string: Dashboard -> your project -> Connect (use the pooled connection string)
DATABASE_URL=postgresql://user:password@ep-xxxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require

# Optional: Discord channel webhook for UOA notifications.
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
